{
	"name": "magi",
	"private": true,
	"version": "1.0.2",
	"license": "MIT",
	"description": "Three AI models deliberate in parallel, then converge on a consensus answer — synthesis, voting, or multi-round debate.",
	"repository": {
		"type": "git",
		"url": "https://github.com/retrobit/magi.git"
	},
	"keywords": [
		"ai",
		"llm",
		"consensus",
		"multi-model",
		"sveltekit",
		"evangelion"
	],
	"author": "retrobit",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"knip": "knip",
		"verify": "bun run check && bun run lint && bun run test:coverage && bun run build"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10",
		"@sveltejs/adapter-vercel": "^6.3.4",
		"@sveltejs/kit": "^2.61.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^24.12.4",
		"@vitest/coverage-v8": "^4.1.7",
		"axe-core": "^4.11.4",
		"eslint": "^10",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.18.0",
		"globals": "^17.6.0",
		"jsdom": "^29.1.1",
		"knip": "^6.14.2",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"prettier-plugin-tailwindcss": "^0.7.4",
		"svelte": "^5.55.10",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.3.0",
		"typescript": "~6.0",
		"typescript-eslint": "^8.60.0",
		"vite": "^7",
		"vitest": "^4.1.7"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^3.0.81",
		"@ai-sdk/google": "^3.0.80",
		"@ai-sdk/openai": "^3.0.67",
		"@fontsource/atkinson-hyperlegible": "^5.2.8",
		"@fontsource/michroma": "^5.2.8",
		"@upstash/ratelimit": "^2.0.8",
		"@upstash/redis": "^1.38.0",
		"@vercel/analytics": "^2.0.1",
		"ai": "^6.0.193",
		"dompurify": "^3.4.7",
		"highlight.js": "^11.11.1",
		"lucide-svelte": "^1.0.1",
		"marked": "^18",
		"marked-highlight": "^2.2.4",
		"zod": "^4.4.3"
	}
}
