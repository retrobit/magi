# MAGI API Keys
# Get yours at:
#   Anthropic:   https://console.anthropic.com
#   OpenAI:      https://platform.openai.com
#   Google:      https://aistudio.google.com
#   OpenRouter:  https://openrouter.ai/keys

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OPENROUTER_API_KEY=

# Optional: set to require Bearer token auth on the /api/magi endpoint
# Leave unset when using only the built-in frontend (SvelteKit CSRF handles same-origin protection)
MAGI_API_KEY=

# Optional: organization admin keys for the provider-budget readout
#   ANTHROPIC_ADMIN_KEY — sk-ant-admin-… (Scale/Enterprise plans only)
#   OPENAI_ADMIN_KEY    — sk-admin-…    (created at platform.openai.com → Admin keys)
# When set, the readout fetches that provider's spend; otherwise it shows
# "admin key not configured".
ANTHROPIC_ADMIN_KEY=
OPENAI_ADMIN_KEY=

# Optional: monthly spend caps in USD. When set, the Budget readout shows a
# bar of today's spend against this user-defined ceiling (the provider APIs
# don't expose a per-key hard limit, so this is purely your own budget).
ANTHROPIC_MONTHLY_BUDGET=
OPENAI_MONTHLY_BUDGET=

# Optional: OpenRouter attribution headers. The defaults point at the canonical
# repo + "MAGI" — override on a fork or deployment so OpenRouter's dashboard
# credits your instance instead of upstream.
OPENROUTER_REFERER=
OPENROUTER_TITLE=

# Optional: server log threshold. One of debug, info, warn, error. Lines below
# the active level are dropped. Defaults to `debug` in dev and `info` in prod.
MAGI_LOG_LEVEL=

# Optional: turn on the public-preview chrome — the header PREVIEW chip, the
# splash badge, and the free-tier-only guard (a shake on the Free pill + note)
# on the tier selector. Set to `true` on the live demo; leave unset for a
# private full-feature build. Unlike the keys above this is a PUBLIC_ var, so
# its value ships to the browser (it's just a feature flag — nothing secret).
# Set it here to preview the demo branding locally with `bun run dev`.
PUBLIC_DEMO_MODE=
